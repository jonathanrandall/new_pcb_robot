<?xml version="1.0"?>
<robot name="pan_tilt_test" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:include filename="$(find autonomous_robot)/description/pan_tilt_xacros/pan_tilt.xacro"/>

  <!-- Base link -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.01"/>
      </geometry>
      <material name="base_gray">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.01"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
  </link>

  <!-- Instantiate the pan-tilt mechanism -->
  <xacro:pan_tilt_mechanism parent="base_link">
    <origin xyz="0 0 0.01" rpy="0 0 0"/>
  </xacro:pan_tilt_mechanism>

</robot>
