<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Pan-Tilt Mechanism with Camera Mount for MG995/MG996 Servos -->

  <xacro:macro name="pan_tilt_mechanism" params="parent *origin">

    <!-- Properties for MG995/MG996 Servo Dimensions -->
    <xacro:property name="servo_length" value="0.0408"/>  <!-- 40.8mm -->
    <xacro:property name="servo_width" value="0.0197"/>   <!-- 19.7mm -->
    <xacro:property name="servo_height" value="0.0428"/>  <!-- 42.8mm -->
    <xacro:property name="servo_horn_radius" value="0.008"/> <!-- 8mm -->
    <xacro:property name="servo_horn_height" value="0.004"/> <!-- 4mm -->

    <!-- Base Properties -->
    <xacro:property name="base_length" value="0.06"/>
    <xacro:property name="base_width" value="0.06"/>
    <xacro:property name="base_height" value="0.025"/>

    <!-- Camera Properties -->
    <xacro:property name="camera_length" value="0.02"/>
    <xacro:property name="camera_width" value="0.028"/>
    <xacro:property name="camera_height" value="0.027"/>

    <xacro:property name="camera_mount_w" value="0.09"/>
    <xacro:property name="camera_mount_l" value="0.068"/>
    <xacro:property name="camera_mount_h" value="0.085"/>

    <xacro:property name="pan_tilt_leg_l" value="0.025"/>
    <xacro:property name="pan_tilt_leg_w" value="0.058"/>
    <xacro:property name="pan_tilt_leg_h" value="0.065"/>

    <!-- Mount Properties -->
    <xacro:property name="mount_thickness" value="0.0052"/>
    <xacro:property name="bracket_height" value="0.04"/>

    <!-- Materials -->
    <material name="servo_black">
      <color rgba="0.1 0.1 0.1 1.0"/>
    </material>

    <material name="bracket_gray">
      <color rgba="0.5 0.5 0.5 1.0"/>
    </material>

    <material name="camera_black">
      <color rgba="0.05 0.05 0.05 1.0"/>
    </material>

    <material name="camera_red">
      <color rgba="0.8 0.05 0.05 1.0"/>
    </material>

    <material name="camera_blue">
      <color rgba="0.05 0.05 0.8 1.0"/>
    </material>

    <!-- Base Link -->
    <joint name="pan_tilt_base_joint" type="fixed">
      <xacro:insert_block name="origin"/>
      <parent link="${parent}"/>
      <child link="pan_tilt_base_link"/>
    </joint>

    <link name="pan_tilt_base_link">
      <visual>
        <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${base_length} ${base_width} ${base_height}"/>
        </geometry>
        <material name="bracket_gray"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${base_length} ${base_width} ${base_height}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
        <mass value="0.05"/>
        <inertia ixx="0.00002" ixy="0.0" ixz="0.0"
                 iyy="0.00002" iyz="0.0"
                 izz="0.00003"/>
      </inertial>
    </link>

    <!-- Pan Servo (Bottom Servo - Yaw rotation) -->
    <link name="pan_servo_bracket_link">
      <visual>
        <origin xyz="0 0 ${servo_height/2}" rpy="1.57 0 0"/>
        <geometry>
          <!-- <mesh filename="file://$(find xarm_description)/meshes/stls/link5.stl" scale="1.0 1.0 1.0" /> -->
          <mesh filename="file://$(find pan_tilt_description)/urdf/meshes/stls/PAN-TILT_BASE_V1_fixed.stl" scale="0.001 0.001 0.001" />
          <!-- <box size="${servo_length} ${servo_width} ${servo_height}"/> -->
        </geometry>
        <material name="bracket_gray"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${servo_height/2}" rpy="1.57 0 0"/>
        <geometry>
          <mesh filename="file://$(find pan_tilt_description)/urdf/meshes/stls/PAN-TILT_BASE_V1_fixed.stl" scale="0.001 0.001 0.001" />
          <!-- <mesh filename="file://$(find pan_tilt_description)/urdf/meshes/stls/PAN-TILT_BASE_V1_fixed.dae" scale="0.001 0.001 0.001" /> -->
          <!-- <box size="0.06 0.06 0.06"/> -->
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${servo_height/2}" rpy="1.57 0 0"/>
        <mass value="0.055"/>
        <inertia ixx="0.00001" ixy="0.0" ixz="0.0"
                 iyy="0.00001" iyz="0.0"
                 izz="0.00001"/>
      </inertial>
    </link>

    <joint name="pan_servo_bracket_joint" type="fixed">
      <origin xyz="0 0 ${base_height}" rpy="0 0 0"/>
      <parent link="pan_tilt_base_link"/>
      <child link="pan_servo_bracket_link"/>
    </joint>

    <link name="pan_servo_link">
      <visual>
        <origin xyz="0 0 ${servo_height/2}" rpy="0 0 0"/>
        <geometry>
          <!-- <mesh filename="file://$(find xarm_description)/meshes/stls/link5.stl" scale="1.0 1.0 1.0" /> -->
          <!-- <mesh filename="file://$(find pan_tilt_description)/urdf/meshes/stls/PAN-TILT_BASE_V1_fixed.stl" scale="0.001 0.001 0.001" /> -->
          <box size="${servo_length} ${servo_width} ${servo_height}"/>
        </geometry>
        <material name="servo_black"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${servo_height/2}" rpy="0 0 0"/>
        <geometry>
          <!-- <mesh filename="file://$(find pan_tilt_description)/urdf/meshes/stls/PAN-TILT_BASE_V1_fixed.dae" scale="0.001 0.001 0.001" /> -->
          <box size="${servo_length} ${servo_width} ${servo_height}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${servo_height/2}" rpy="0 0 0"/>
        <mass value="0.055"/>
        <inertia ixx="0.00001" ixy="0.0" ixz="0.0"
                 iyy="0.00001" iyz="0.0"
                 izz="0.00001"/>
      </inertial>
    </link>

    <joint name="pan_servo_joint" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="pan_servo_bracket_link"/>
      <child link="pan_servo_link"/>
    </joint>

    <!-- Pan Link (Rotating part controlled by pan servo) -->
    <link name="pan_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find pan_tilt_description)/urdf/meshes/stls/PAN-TILT_ROTOR_V2_fixed.stl" scale="0.001 0.001 0.001" />
          <!-- <box size="${mount_thickness} ${servo_width + 0.01} ${bracket_height/4}"/> -->
        </geometry>
        <material name="bracket_gray"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find pan_tilt_description)/urdf/meshes/stls/PAN-TILT_ROTOR_V2_fixed.stl" scale="0.001 0.001 0.001" />
          <!-- <box size="${mount_thickness} ${servo_width + 0.01} ${bracket_height/4}"/> -->
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.02"/>
        <inertia ixx="0.000005" ixy="0.0" ixz="0.0"
                 iyy="0.000005" iyz="0.0"
                 izz="0.000001"/>
      </inertial>
    </link>

    <joint name="pan_joint" type="revolute">
      <!-- <origin xyz="0 0 ${servo_height/2 + servo_horn_height}" rpy="0 0 0"/> -->
      <origin xyz="-${servo_length/4} 0 ${servo_height + servo_horn_height}" rpy="0 0 0"/>
      <parent link="pan_servo_link"/>
      <child link="pan_link"/>
      <axis xyz="0 0 1"/>
      <limit lower="${-pi}" upper="${pi}" effort="10.0" velocity="1.57"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <!-- Tilt Servo (Top Servo - Pitch rotation) -->
    <link name="tilt_servo_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <!-- <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/> -->
        <geometry>
          <!-- <box size="${servo_height} ${servo_height} ${servo_length} "/> -->
          <box size="${servo_length} ${servo_width} ${servo_height}"/>
        </geometry>
        <material name="servo_black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
        <geometry>
          <!-- <box size="${servo_height} ${servo_width} ${servo_length} "/> -->
          <box size="${servo_length} ${servo_width} ${servo_height}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
        <mass value="0.055"/>
        <inertia ixx="0.00001" ixy="0.0" ixz="0.0"
                 iyy="0.00001" iyz="0.0"
                 izz="0.00001"/>
      </inertial>
    </link>

    <joint name="tilt_servo_joint" type="fixed">
      <origin xyz="0 ${servo_height/4} ${mount_thickness*2}" rpy="0 0 0"/>
      <parent link="pan_link"/>
      <child link="tilt_servo_link"/>
    </joint>

    <!-- Tilt Link (Rotating part controlled by tilt servo) -->
    <link name="tilt_link">
      <visual>
        <origin xyz="0 -0.022 0" rpy="0 0 0"/>
        <!-- <origin xyz="-${servo_length/4 + 0.01} 0 ${servo_length}" rpy="-1.57 0 1.57"/> -->
        <geometry>
          <!-- <box size="${servo_length + 0.02} ${servo_width + 0.01} ${mount_thickness}"/> -->
          <mesh filename="file://$(find pan_tilt_description)/urdf/meshes/stls/PAN-TILT_LEG_V2_fixed.stl" scale="0.001 0.001 0.001" />
        </geometry>
        <material name="bracket_gray"/>
      </visual>
      <collision>
        <origin xyz="0 -0.022 0" rpy="0 0 0"/>
        <!-- <origin xyz="-${servo_length/4 + 0.01} 0 ${servo_length}" rpy="-1.57 0 1.57"/> -->
        <geometry>
          <!-- <box size="${servo_length + 0.02} ${servo_width + 0.01} ${mount_thickness}"/> -->
          <mesh filename="file://$(find pan_tilt_description)/urdf/meshes/stls/PAN-TILT_LEG_V2_fixed.stl" scale="0.001 0.001 0.001" />
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 -0.022 0" rpy="0 0 0"/>
        <!-- <origin xyz="-${servo_length/4 + 0.01} 0 ${servo_length}" rpy="-1.57 0 1.57"/> -->
        <mass value="0.02"/>
        <inertia ixx="0.000001" ixy="0.0" ixz="0.0"
                 iyy="0.000005" iyz="0.0"
                 izz="0.000005"/>
      </inertial>
    </link>

    <joint name="tilt_joint" type="revolute">
      <!-- <origin xyz="0 0 0" rpy="0 0 0"/> -->
      <origin xyz="${servo_length/4} 0.005 ${servo_height/10}" rpy="-1.4 0 1.57"/>
      <parent link="tilt_servo_link"/>
      <child link="tilt_link"/>
      <axis xyz="1 0 0"/>
      <limit lower="${-pi/2}" upper="${pi/2}" effort="10.0" velocity="1.57"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <!-- Camera Link -->
    <link name="pan_tilt_camera_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 1.57"/>
        <geometry>
          <mesh filename="file://$(find pan_tilt_description)/urdf/meshes/stls/pi_stand_final_v2-Body_v2_fixed.stl" scale="0.001 0.001 0.001" />
          <!-- <box size="${camera_length} ${camera_width} ${camera_height}"/> -->
        </geometry>
        <material name="camera_blue"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 1.57"/>
        <geometry>
          <!-- <box size="${camera_length} ${camera_width} ${camera_height}"/> -->
          <mesh filename="file://$(find pan_tilt_description)/urdf/meshes/stls/pi_stand_final_v2-Body_v2_fixed.stl" scale="0.001 0.001 0.001" />
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 1.57"/>
        <mass value="0.01"/>
        <inertia ixx="0.000001" ixy="0.0" ixz="0.0"
                 iyy="0.000001" iyz="0.0"
                 izz="0.000001"/>
      </inertial>
    </link>

    <joint name="camera_mount_joint" type="fixed">
      <origin xyz="0 -${pan_tilt_leg_h/2 +0.022+ camera_mount_h/2} 0" rpy="0 1.57 -1.57"/>
      <!-- <origin xyz="0 0 0" rpy="0 0 0"/> -->
      <parent link="tilt_link"/>
      <child link="pan_tilt_camera_link"/>
    </joint>

    <!-- Camera Link -->
    <link name="rgb_camera_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${camera_length} ${camera_width} ${camera_height}"/>
        </geometry>
        <material name="camera_red"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${camera_length} ${camera_width} ${camera_height}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.01"/>
        <inertia ixx="0.000001" ixy="0.0" ixz="0.0"
                 iyy="0.000001" iyz="0.0"
                 izz="0.000001"/>
      </inertial>

  
    </link>

    <joint name="rgb_camera_joint" type="fixed">
      <origin xyz="${camera_mount_l/2} 0.024 -0.004" rpy="0 0 0"/>
      <!-- <origin xyz="0 0 0" rpy="0 0 0"/> -->
      <parent link="pan_tilt_camera_link"/>
      <child link="rgb_camera_link"/>
    </joint>

    <!-- Camera Optical Frame (for proper ROS camera convention) -->
    <link name="rgb_camera_optical_link"/>

    <joint name="camera_optical_joint" type="fixed">
      <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
      <parent link="rgb_camera_link"/>
      <child link="rgb_camera_optical_link"/>
    </joint>

  </xacro:macro>


  <gazebo reference="rgb_camera_link">
    <sensor name="depth_camera" type="depth_camera">
      <camera>
        <horizontal_fov>1.25</horizontal_fov>
        <image>
          <width>320</width>
          <height>240</height>
          <format>R8G8B8</format>
          <!-- <format>L16</format> -->
        </image>
        <clip>
          <near>0.1</near>
          <far>20</far>
        </clip>
        <!-- <optical_frame_id>camera_link</optical_frame_id> -->
        <optical_frame_id>rgb_camera_optical_link</optical_frame_id>
        <camera_info_topic>camera/depth/camera_info</camera_info_topic>
      </camera>
      <always_on>1</always_on>
      <update_rate>20</update_rate>
      <visualize>true</visualize>
      <topic>camera/depth/image_raw</topic>
      <point_cloud_topic>camera/depth/points</point_cloud_topic>
      <gz_frame_id>rgb_camera_link</gz_frame_id>
    </sensor>
    <sensor name="camera" type="camera">
      <camera>
        <horizontal_fov>1.25</horizontal_fov>
        <image>
          <width>320</width>
          <height>240</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>20</far>
        </clip>
        <optical_frame_id>rgb_camera_optical_link</optical_frame_id>
        <camera_info_topic>camera/camera_info</camera_info_topic>
      </camera>
      <always_on>1</always_on>
      <update_rate>20</update_rate>
      <visualize>true</visualize>
      <topic>camera/image_raw</topic>
      <!-- <gz_frame_id>rgb_camera_link</gz_frame_id> -->
    </sensor>
  </gazebo>
       
